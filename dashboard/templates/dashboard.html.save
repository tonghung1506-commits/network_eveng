  /* Summary */
  .summary {
    display: flex; gap: 0;
    padding: 12px 32px;
    border-bottom: 1px solid var(--border);
    background: rgba(10,21,32,0.8);
  }
  .sum-item {
    padding-right: 28px; margin-right: 28px;
    border-right: 1px solid var(--border);
  }
  .sum-item:last-child { border-right: none; }
  .sum-val {
    font-family: var(--mono); font-size: 30px; font-weight: 700; line-height: 1;
  }
  .sum-label {
    font-size: 10px; text-transform: uppercase;
    letter-spacing: 1.5px; color: var(--dim); margin-top: 3px;
  }
  .c-blue   { color: var(--accent); }
  .c-green  { color: var(--green); }
  .c-red    { color: var(--danger); }
  .c-warn   { color: var(--warn); }

  /* Action bar */
  .actions {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 32px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--mono); font-size: 12px;
    padding: 8px 20px; border-radius: 4px;
    border: 1px solid; background: transparent;
    cursor: pointer; letter-spacing: 1px;
    text-transform: uppercase; transition: all 0.2s;
  }
  .btn:hover { filter: brightness(1.3); }
  .btn-refresh { color: var(--accent);  border-color: var(--accent); }
  .btn-deploy  { color: var(--green);   border-color: var(--green); }
